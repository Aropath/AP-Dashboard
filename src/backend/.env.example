# Database
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/growthadvisor"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Google OAuth (sign in)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GA4 OAuth (analytics connection)
# Uses the SAME Google OAuth client ID + secret as above
# Just add the redirect URI below to your OAuth client's authorized redirect URIs
GA4_REDIRECT_URI="http://localhost:5000/api/ga4/auth/callback"

# Internal API key — used by port 5001 to fetch GA4 tokens from port 5000
# Generate any long random string: openssl rand -hex 32
INTERNAL_API_KEY="your-internal-api-key-change-this"

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS + OAuth redirects)
FRONTEND_URL="http://localhost:3000"

# Analytics service URL (port 5001)
ANALYTICS_SERVICE_URL="http://localhost:5001"
